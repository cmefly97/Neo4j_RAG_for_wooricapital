# ===== Neo4j =====
# 리모트 서버 사용 (Bolt 포트 7687). TLS 필요시 bolt+s:// 또는 neo4j+s://
NEO4J_URI=bolt://223.130.140.218:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD='your-password'

# ===== LLM: Claude (Anthropic) =====
ANTHROPIC_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_EXTRACT_MODEL=claude-opus-4-8
ANTHROPIC_ANSWER_MODEL=claude-opus-4-8

# ===== LLM: HyperCLOVA X (사내 게이트웨이, OpenAI 호환) =====
HCX_PROVIDER=hyperclova
HCX_API_KEY=
HCX_BASE_URL=https://namc-aigw.io.naver.com/v1/chat/completions
HCX_EXTRACT_MODEL=HyperCLOVAX-SEED-32B-Think-Text
HCX_ANSWER_MODEL=HyperCLOVAX-SEED-32B-Think-Text

# ===== LLM: Qwen (전용 엔드포인트, OpenAI 호환) =====
# QWEN_BASE_URL 미설정 시 HCX 게이트웨이 값 재사용. api_key도 동일.
QWEN_MODEL=Qwen/Qwen3.6-35B-A3B
QWEN_BASE_URL=http://<host>:8000/v1/chat/completions
# QWEN_API_KEY=

# ===== App =====
BACKEND_PORT=8000
SOURCE_DIR=./source
GRAPH_JSON=./graph_output/graph.json

# ===== Embeddings (bge-m3, 사내 게이트웨이 /v1/embeddings) =====
# EMBED_API_KEY 비우면 HCX_API_KEY 재사용. base 비우면 HCX_BASE_URL 재사용.
EMBED_BASE_URL=http://<host>:8001/v1
EMBED_API_KEY=
EMBED_MODEL=BAAI/bge-m3
EMBED_DIM=1024

# ===== LLM: HCX-30B-Text (사내 게이트웨이, OpenAI 호환, thinking) =====
HCX30_BASE_URL=http://<host>:11000/v1/chat/completions
HCX30_API_KEY=
HCX30_MODEL=hcx-agent-05
